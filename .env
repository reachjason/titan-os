# Committed, non-secret defaults. PROD-ONLY (see CLAUDE.md).
# These Convex URLs are public (they ship in the frontend bundle), so it's safe
# to commit them. `.env.local` overrides this file locally if present.
#
# NOTE: CONVEX_DEPLOYMENT is intentionally NOT set here — it lives only in the
# gitignored `.env.local` for local CLI use. In CI, `convex deploy` authenticates
# via the CONVEX_DEPLOY_KEY secret instead; a committed CONVEX_DEPLOYMENT would
# conflict with that and break the CI deploy.

# Frontend connects to prod Convex:
VITE_CONVEX_URL=https://robust-grasshopper-674.convex.cloud
VITE_CONVEX_SITE_URL=https://robust-grasshopper-674.convex.site
