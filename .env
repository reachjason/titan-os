# Committed, non-secret defaults.
# Local development should use `.env.local`, generated/updated by
# `npx convex deployment select dev` or `npx convex dev`.
#
# NOTE: these placeholder values intentionally do not point at production.
# If Vite complains about the Convex URL, run `npm run dev` so Convex writes
# the correct dev deployment URL into `.env.local`.

VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
