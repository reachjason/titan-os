# Local development against the shared Convex dev deployment.
# Copy this file to `.env.local` before running locally:
#
#   cp .env.local.example .env.local
#
# These values are public deployment identifiers/URLs, not secrets.

CONVEX_DEPLOYMENT=dev:abundant-jaguar-978 # team: viral-sangani, project: titan-os
VITE_CONVEX_URL=https://abundant-jaguar-978.convex.cloud
VITE_CONVEX_SITE_URL=https://abundant-jaguar-978.convex.site
